---
// Home-page teasers for the async-work and referral pages: two linked cards
// that summarise each page and point visitors through to the full story.
import { CalendarX, Gift, ArrowRight } from "@lucide/astro";

const highlights = [
  {
    icon: CalendarX,
    href: "/async-work",
    title: "We Work Async",
    body: "No mandatory meetings, no phone tag. Your whole project runs over email and messages, on a schedule that suits you.",
    linkText: "How async works",
  },
  {
    icon: Gift,
    href: "/referrals",
    title: "Refer a Friend, Earn 10%",
    body: "Know someone who needs a website? Send them our way and we'll send you 10% of their first invoice as a thank you.",
    linkText: "About our referral programme",
  },
];
---

<section id="good-to-know" class="section" aria-labelledby="good-to-know-title">
  <sparkly-text
    number-of-sparkles="5"
    style="--sparkly-text-color: color-mix(in srgb, currentColor, var(--primary) 100%);"
  >
    <mark>the purr-ks of working with us</mark>
  </sparkly-text>

  <h2 id="good-to-know-title">Good to Know</h2>
  <p>
    A couple of things that make working with us a little different, and a
    little more rewarding.
  </p>

  <div class="highlight-grid">
    {
      highlights.map((item, index) => {
        const Icon = item.icon;
        return (
          <a
            class="highlight-card"
            href={item.href}
            style={`--delay: ${index * 0.1}s`}
          >
            <span class="highlight-icon" aria-hidden="true">
              <Icon size={26} />
            </span>
            <h3 class="highlight-title">{item.title}</h3>
            <p class="highlight-body">{item.body}</p>
            <span class="highlight-more">
              {item.linkText}
              <ArrowRight size={18} aria-hidden="true" />
            </span>
          </a>
        );
      })
    }
  </div>
</section>

<style>
  .highlight-grid {
    inline-size: 100%;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .highlight-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    padding: var(--space-l) var(--space-m);
    background: hsl(from var(--card) h s l / 0.05);
    border: 1px solid hsl(from var(--border) h s l / 0.2);
    border-radius: var(--radius);
    backdrop-filter: blur(8px);
    color: inherit;
    text-decoration: none;
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.3s ease;
    animation: fadeInUp 0.6s ease-out var(--delay) both;
  }

  .highlight-card:hover {
    border-color: hsl(from var(--primary) h s l / 0.4);
    box-shadow: 0 4px 20px hsl(from var(--primary) h s l / 0.1);
    transform: translateY(-2px);
  }

  .highlight-icon {
    display: grid;
    place-items: center;
    inline-size: 3rem;
    block-size: 3rem;
    border-radius: var(--radius);
    color: var(--primary);
    background: hsl(from var(--primary) h s l / 0.1);
    margin-block-end: var(--space-2xs);
  }

  .highlight-title {
    font-size: var(--step-1);
  }

  .highlight-body {
    font-size: var(--step--1);
    color: hsl(from var(--foreground) h s l / 0.7);
  }

  .highlight-more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-block-start: var(--space-2xs);
    font-size: var(--step--1);
    font-weight: 600;
    color: var(--primary);
  }

  .highlight-more :global(svg) {
    transition: transform 0.3s ease;
  }

  .highlight-card:hover .highlight-more :global(svg) {
    transform: translateX(4px);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 640px) {
    .highlight-grid {
      grid-template-columns: 1fr;
    }

    /* Icon sits beside the title instead of above it */
    .highlight-card {
      display: grid;
      grid-template-columns: auto 1fr;
      align-items: center;
      column-gap: var(--space-xs);
    }

    .highlight-icon {
      grid-column: 1;
      grid-row: 1;
      margin-block-end: 0;
    }

    .highlight-title {
      grid-column: 2;
      grid-row: 1;
    }

    .highlight-body,
    .highlight-more {
      grid-column: 1 / -1;
    }
  }
</style>
