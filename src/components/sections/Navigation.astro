---
import { navigation, isActive } from "@/lib/navigation";
import type { NavItem } from "@/lib/navigation";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<nav class="navigation">
  <button
    class="hamburger"
    aria-label="Toggle menu"
    aria-expanded="false"
    aria-controls="site-nav-content"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>

  <div class="overlay"></div>

  <div class="nav-content" id="site-nav-content">
    <a href="/#" class="title" aria-label="KittyCode Creative, go to home">
      <img src="/favicon.png" alt="" />
      <span class="nav-title">KittyCode Creative</span>
    </a>

    <div class="main-nav">
      {
        navigation.main.map((item: NavItem) => (
          <a
            href={item.path}
            class:list={[
              "nav-link",
              { active: isActive(item.path, currentPath) },
            ]}
            aria-label={item.ariaLabel}
          >
            {item.label}
          </a>
        ))
      }

      <label for="theme-toggle-desktop" class="toggle">
        <input
          id="theme-toggle-desktop"
          type="checkbox"
          aria-label="Toggle dark mode"
        />
        <div></div>
      </label>
    </div>

    <div class="secondary-nav">
      {
        navigation.secondary.map((item: NavItem) => (
          <a
            href={item.path}
            class:list={[
              "nav-link",
              { active: isActive(item.path, currentPath) },
            ]}
            aria-label={item.ariaLabel}
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <div class="mobile-theme-section">
      <span id="mobile-theme-label">Theme</span>
      <label for="theme-toggle-mobile" class="mobile-toggle">
        <input
          id="theme-toggle-mobile"
          type="checkbox"
          aria-labelledby="mobile-theme-label"
        />
        <div></div>
      </label>
    </div>
  </div>
</nav>

<script>
  import { isActive } from "@/lib/navigation";

  const nav = document.querySelector<HTMLElement>(".navigation");
  const hamburger = nav?.querySelector<HTMLButtonElement>(".hamburger");
  const overlay = nav?.querySelector<HTMLElement>(".overlay");
  const content = nav?.querySelector<HTMLElement>(".nav-content");

  if (nav && hamburger && overlay && content) {
    const themeToggles = nav.querySelectorAll<HTMLInputElement>(
      ".toggle input, .mobile-toggle input",
    );
    const mobileQuery = window.matchMedia("(max-width: 768px)");
    let menuOpen = false;
    let lastScrollY = 0;

    // The drawer sits off-canvas when closed on mobile; `inert` keeps its
    // links out of the tab order and accessibility tree while invisible.
    const syncInert = () => {
      content.inert = mobileQuery.matches && !menuOpen;
    };

    const setMenu = (open: boolean) => {
      menuOpen = open;
      nav.classList.toggle("menu-open", open);
      hamburger.classList.toggle("open", open);
      hamburger.setAttribute("aria-expanded", String(open));
      document.body.classList.toggle("nav-open", open);
      syncInert();
    };

    // Theme: the initial class is applied pre-paint by the inline script in
    // Head.astro; here we only keep the toggles in sync and handle changes.
    const syncToggles = () => {
      const dark = document.documentElement.classList.contains("dark");
      themeToggles.forEach((input) => {
        input.checked = dark;
      });
    };

    themeToggles.forEach((input) => {
      input.addEventListener("change", () => {
        document.documentElement.classList.toggle("dark", input.checked);
        localStorage.setItem("theme", input.checked ? "dark" : "light");
        syncToggles();
      });
    });
    syncToggles();

    window
      .matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", (e) => {
        if (localStorage.getItem("theme") === null) {
          document.documentElement.classList.toggle("dark", e.matches);
          syncToggles();
        }
      });

    // Auto-hide on scroll
    window.addEventListener(
      "scroll",
      () => {
        const y = window.scrollY;
        if (Math.abs(y - lastScrollY) < 10) return;
        const visible = y < lastScrollY || y < 100;
        nav.classList.toggle("hidden", !visible);
        content.style.visibility = visible ? "visible" : "hidden";
        if (!visible && menuOpen) setMenu(false);
        lastScrollY = y;
      },
      { passive: true },
    );

    hamburger.addEventListener("click", () => setMenu(!menuOpen));
    overlay.addEventListener("click", () => setMenu(false));

    document.addEventListener("mousedown", (e) => {
      if (menuOpen && e.target instanceof Node && !nav.contains(e.target)) {
        setMenu(false);
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setMenu(false);
    });

    // Swipe left on the open drawer closes it
    let touchStartX = 0;
    content.addEventListener(
      "touchstart",
      (e) => {
        touchStartX = e.touches[0].clientX;
      },
      { passive: true },
    );
    content.addEventListener(
      "touchmove",
      (e) => {
        if (menuOpen && touchStartX - e.touches[0].clientX > 50) {
          setMenu(false);
        }
      },
      { passive: true },
    );

    // Any nav link click closes the menu
    nav.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => setMenu(false));
    });

    // The nav persists across view transitions, so re-sync the active link
    // and close the menu after every client-side navigation.
    const syncActive = () => {
      const path = window.location.pathname;
      nav.querySelectorAll<HTMLAnchorElement>("a.nav-link").forEach((a) => {
        a.classList.toggle(
          "active",
          isActive(a.getAttribute("href") ?? "", path),
        );
      });
    };

    document.addEventListener("astro:page-load", () => {
      syncActive();
      syncToggles();
      setMenu(false);
    });

    mobileQuery.addEventListener("change", syncInert);
    syncInert();
  }
</script>

<style is:global>
  /* Base Navigation */
  .navigation {
    position: fixed;
    z-index: 1000;
    transition: transform 0.3s ease;
    margin: 0 auto;
  }

  .navigation.hidden {
    transform: translateY(-100px);
  }

  /* Hamburger (hidden on desktop) */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: space-around;
    inline-size: 44px;
    block-size: 44px;
    background: hsl(from var(--card) h s l / 0.15);
    backdrop-filter: blur(8px);
    border: none;
    border-radius: 12px;
    cursor: pointer;
    padding: 8px;
    transition: all 0.3s ease;
    position: relative;
    z-index: 5;
  }

  .hamburger span {
    inline-size: 100%;
    block-size: 3px;
    background: var(--foreground);
    border-radius: 3px;
    transition: all 0.3s ease;
    transform-origin: center;
  }

  .hamburger.open span:nth-child(1) {
    transform: rotate(45deg) translate(7px, 7px);
  }

  .hamburger.open span:nth-child(2) {
    opacity: 0;
    transform: scale(0);
  }

  .hamburger.open span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -6px);
  }

  /* Desktop Navigation Content */
  .nav-content {
    display: flex;
    justify-content: space-between;
    inline-size: 100vw;
    align-items: center;
    padding: 1rem;
    background: hsl(from var(--background) h s l / 0.6);
    backdrop-filter: blur(0.75rem);
    gap: var(--space-3xl);
    border-block-end: 1px solid var(--card);
    transition: all 0.3s ease;
  }

  .title {
    margin-inline-start: var(--space-m);
    display: flex;
    align-items: center;
    gap: var(--space-s);
    font-size: var(--step-1);
    font-weight: 600;
    text-decoration: none;
    color: inherit;
    transition: color 0.3s ease;
  }

  .title img {
    inline-size: 60px;
  }

  .title:hover .nav-title {
    color: var(--primary);
  }

  .title:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 4px;
    border-radius: 8px;
  }

  .main-nav {
    display: flex;
    gap: var(--space-m);
    margin-inline-end: var(--space-s);
  }

  .nav-link {
    color: hsl(from var(--foreground) h s l / 0.7);
    text-decoration: none;
    font-weight: 500;
    transition:
      color 0.3s ease,
      border-color 0.3s ease;
    padding: 0.25rem 0.5rem;
    position: relative;
    border-block-end: 2px solid transparent;
  }

  .nav-link:hover {
    color: var(--primary);
    border-block-end-color: var(--primary);
  }

  .nav-link.active {
    color: var(--primary);
    font-weight: 600;
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  .secondary-nav,
  .mobile-theme-section {
    display: none;
  }

  .overlay {
    display: none;
  }

  body.nav-open {
    overflow: hidden;
  }

  /* Theme Toggle */
  .toggle,
  .mobile-toggle {
    transform: scale(0.66);
    transform-origin: center;
    cursor: pointer;
    z-index: 10;
    transition: 0.5s ease all;
  }

  .toggle:hover,
  .mobile-toggle:hover {
    transform: scale(0.55) rotate(45deg);
    transition: 0.5s ease all;
  }

  .toggle input,
  .mobile-toggle input {
    display: none;
  }

  .toggle input + div,
  .mobile-toggle input + div {
    border-radius: 50%;
    inline-size: 36px;
    block-size: 36px;
    position: relative;
    box-shadow: inset 12px -12px 0 0 var(--toggle-color);
    transform: scale(1) rotate(-2deg);
    transition:
      box-shadow 0.5s ease 0s,
      transform 0.4s ease 0.1s;
  }

  .toggle input + div:before,
  .mobile-toggle input + div:before {
    content: "";
    inline-size: inherit;
    block-size: inherit;
    border-radius: inherit;
    position: absolute;
    inset-inline-start: 0;
    inset-block-start: 0;
    background: light-dark(transparent, var(--toggle-color));
    transition: all 0.3s ease;
  }

  .toggle input + div:after,
  .mobile-toggle input + div:after {
    content: "";
    block-size: 4px;
    margin: -2px 0 0 -4px;
    inline-size: 4px;
    border-radius: 50%;
    position: absolute;
    inset-block-start: 50%;
    inset-inline-start: 50%;
    box-shadow:
      1px -22px 0 var(--toggle-color),
      1px 23px 0 var(--toggle-color),
      23px 0 0 var(--toggle-color),
      -21px 0 0 var(--toggle-color),
      17px 15px 0 var(--toggle-color),
      -15px 15px 0 var(--toggle-color),
      17px -15px 0 var(--toggle-color),
      -15px -15px 0 var(--toggle-color);
    transform: scale(0);
    transition: all 0.3s ease;
  }

  .toggle input:checked + div,
  .mobile-toggle input:checked + div {
    box-shadow: inset 32px -32px 0 0 var(--primary);
    transform: scale(0.5) rotate(0deg);
    transition:
      transform 0.3s ease 0.1s,
      box-shadow 0.2s ease 0s;
  }

  .toggle input:checked + div:before,
  .mobile-toggle input:checked + div:before {
    background: var(--toggle-color);
    transition: all 0.3s ease 0.1s;
  }

  .toggle input:checked + div:after,
  .mobile-toggle input:checked + div:after {
    transform: scale(1.5);
    transition: transform 0.5s ease 0.15s;
  }

  .hamburger:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  /* Mobile Responsive */

  @media screen and (max-width: 1200px) {
    .title {
      font-size: var(--step-0);
    }

    .title img {
      inline-size: 48px;
    }

    .main-nav {
      gap: var(--space-s);
    }
  }

  @media screen and (max-width: 1150px) {
    .main-nav {
      gap: var(--space-xs);
    }
    .nav-content {
      gap: var(--space-m);
    }
  }

  @media screen and (max-width: 950px) {
    .title .nav-title {
      visibility: hidden;
      inline-size: 1px;
    }
  }

  @media screen and (max-width: 768px) {
    .navigation {
      inset-block-start: 1rem;
      inset-inline-end: 1rem;
      inset-inline-start: auto;
      transform: none;
    }

    .navigation.hidden {
      transform: translateY(-100px);
    }

    .hamburger {
      display: flex;
    }

    .hamburger:hover {
      transform: scale(1.05);
    }

    .nav-content {
      position: fixed;
      inset-block-start: 0;
      inset-inline: 0;
      inline-size: 100%;
      max-inline-size: none;
      block-size: 100dvh;
      background: hsl(from var(--background) h s l / 0.9);
      backdrop-filter: blur(12px);
      border-radius: 0;
      transform: translateX(100%);
      transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      flex-direction: column;
      padding-block: calc(5rem + env(safe-area-inset-top, 0px))
        calc(2rem + env(safe-area-inset-bottom, 0px));
      padding-inline: 2rem;
      gap: var(--space-l);
      overflow-y: auto;
      overscroll-behavior: contain;
      box-shadow: none;
    }

    .title {
      margin-inline-end: 0;
      margin-inline-start: 0;
    }

    .title .nav-title {
      visibility: unset;
      inline-size: auto;
    }

    .menu-open .nav-content {
      transform: translateX(0);
    }

    .main-nav {
      flex-direction: column;
      align-items: center;
      gap: var(--space-m);
      margin-inline-end: 0;
    }

    .nav-link {
      font-size: var(--step-0);
      padding: 0.25rem 2rem;
      border-block-end: 1px solid transparent;
      position: relative;
    }

    .nav-link:hover {
      border-block-end-color: var(--primary);
    }

    .secondary-nav {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-s);
      inline-size: 70%;
      padding-block-start: var(--space-l);
      border-block-start: 1px solid hsl(from var(--card) h s l / 0.5);
    }

    .secondary-nav .nav-link {
      font-size: var(--step--1);
    }

    .toggle {
      display: none;
    }

    .mobile-theme-section {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 2rem 0;
      border-block-start: 1px solid hsl(from var(--card) h s l / 1);
      margin-block-start: auto;
      inline-size: 70%;
    }

    .menu-open .overlay {
      display: block;
      position: fixed;
      inset: 0;
      block-size: 100dvh;
      background: rgba(0, 0, 0, 0.5);
      animation: navFadeIn 0.3s ease;
    }

    @keyframes navFadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }
  }
</style>
