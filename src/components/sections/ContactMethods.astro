---
import IconCardGrid from "@/components/ui/IconCardGrid.astro";
import { Mail, MessageCircle, MapPin, Clock } from "@lucide/astro";

const items = [
  {
    icon: Mail,
    title: "Email us",
    body: "hello@kittycodecreative.com",
    href: "mailto:hello@kittycodecreative.com",
  },
  {
    icon: MessageCircle,
    title: "WhatsApp us",
    body: "+44 7480 694425",
    href: "https://wa.me/447480694425",
    external: true,
  },
  {
    icon: MapPin,
    title: "Where we are",
    body: "Eastbourne, East Sussex. Working with clients everywhere.",
  },
  {
    icon: Clock,
    title: "Response time",
    body: "We aim to reply to every enquiry within one working day.",
  },
];
---

<section id="contact-methods" class="section" aria-labelledby="methods-title">
  <mark>whisker me away</mark>
  <h2 id="methods-title">Let's Work Together</h2>
  <p>
    Ready to join the clowder? Whether you have a project in mind or just a few
    questions, we'd love to hear from you. Drop us an email or a WhatsApp
    message, or find us on Facebook, LinkedIn, X and Instagram in the footer
    below.
  </p>

  <IconCardGrid items={items} columns={4} align="center" />
</section>
