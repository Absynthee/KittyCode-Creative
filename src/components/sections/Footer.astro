---
import { navigation, isActive } from "../../lib/navigation";
import type { FooterNavItem, SocialItem } from "../../lib/navigation";
import {
  Linkedin,
  Github,
  Paintbrush,
  Mail,
  Facebook,
  Twitter,
  Instagram,
} from "@lucide/astro";

// Get current path for active state
const currentPath = Astro.url.pathname;

const footerNavLinks = navigation.footer;
const footerLegalLinks = navigation.legal;
const footerSocialLinks = navigation.social;
---

<footer>
  <div class="footer-content">
    <nav class="footer-nav" aria-label="Footer navigation">
      {
        footerNavLinks.map((item: FooterNavItem) => (
          <a
            href={item.path}
            class={`nav-link ${isActive(item.path, currentPath) ? "active" : ""}`}
            aria-label={item.ariaLabel}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <nav class="footer-legal" aria-label="Legal">
      {
        footerLegalLinks.map((item: FooterNavItem) => (
          <a
            href={item.path}
            class={`legal-link ${isActive(item.path, currentPath) ? "active" : ""}`}
            aria-label={item.ariaLabel}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <nav class="footer-social" aria-label="Social media links">
      {
        footerSocialLinks.map((item: SocialItem) => (
          <a
            href={item.path}
            class="social-link"
            aria-label={item.ariaLabel}
            target="_blank"
            rel="noopener noreferrer"
          >
            {item.icon === "linkedin" && <Linkedin size={20} />}
            {item.icon === "email" && <Mail size={20} />}
            {item.icon === "facebook" && <Facebook size={20} />}
            {item.icon === "github" && <Github size={20} />}
            {item.icon === "twitter" && <Twitter size={20} />}
            {item.icon === "instagram" && <Instagram size={20} />}
            {item.icon === "whatsapp" && (
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
            )}

            <span class="sr-only">{item.label}</span>
          </a>
        ))
      }
    </nav>

    <address class="footer-contact">
      <span class="copyright">
        &copy; {new Date().getFullYear()} KittyCode Creative
      </span>

      <span>Web design in Eastbourne, East Sussex, UK</span>
      <a href="mailto:hello@kittycodecreative.com"
        >hello@kittycodecreative.com</a
      >
    </address>
  </div>
</footer>

<style>
  footer {
    position: relative;
    outline: 1px solid hsl(from var(--border) h s l / 0.1);
    padding-block: var(--space-l);
    text-align: center;
    overflow: hidden;
  }

  .footer-content {
    position: relative;
    z-index: 2;
    max-inline-size: 1200px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: 0 var(--space-m);
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-s);
    margin-inline: auto;
  }

  .nav-link {
    color: hsl(from var(--foreground) h s l / 0.7);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s ease;
    padding: 0.25rem 0.75rem;
    position: relative;
  }

  .nav-link:hover {
    color: var(--primary);
    background: hsl(from var(--primary) h s l / 0.1);
  }

  .nav-link.active {
    color: var(--primary);
    font-weight: 600;
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  .footer-social {
    display: flex;
    justify-content: center;
    gap: var(--space-s);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    inline-size: 44px;
    block-size: 44px;
    color: hsl(from var(--foreground) h s l / 0.7);
    background: hsl(from var(--card) h s l / 0.1);
    border: 1px solid hsl(from var(--border) h s l / 0.2);
    border-radius: var(--radius);
    text-decoration: none;
    transition: all 0.2s ease;
    backdrop-filter: blur(8px);
  }

  .social-link:hover {
    color: var(--primary);
    background: hsl(from var(--primary) h s l / 0.1);
    border-color: var(--primary);
    transform: translateY(-2px);
  }

  .social-link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-xs) var(--space-m);
  }

  .legal-link {
    color: hsl(from var(--foreground) h s l / 0.7);
    text-decoration: none;
    font-size: var(--step--1);
    transition: color 0.2s ease;
  }

  .legal-link:hover {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .legal-link.active {
    color: var(--primary);
  }

  .legal-link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .footer-contact {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-xs) var(--space-m);
    font-size: var(--step--1);
    font-weight: 500;
    font-style: normal;
    color: hsl(from var(--foreground) h s l / 0.7);
  }

  .footer-contact a {
    color: hsl(from var(--primary) h s l / 0.9);
    text-decoration: none;
    font-size: var(--step--1);

    transition: color 0.2s ease;
  }

  .footer-contact a:hover {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer-contact a:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .copyright {
    color: hsl(from var(--foreground) h s l / 0.7);
  }

  .copyright a {
    color: hsl(from var(--primary) h s l / 0.9);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .copyright a:hover {
    color: var(--primary);
    text-decoration: underline;
  }

  .copyright a:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .sr-only {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media screen and (max-width: 768px) {
    .footer-nav {
      gap: var(--space-s);
    }

    .nav-link {
      font-size: var(--step--1);
    }

    .social-link {
      inline-size: 40px;
      block-size: 40px;
    }
  }

  @media screen and (max-width: 480px) {
    .footer-nav {
      gap: var(--space-2xs) var(--space-3xs);
    }

    .nav-link {
      padding: 0.25rem 0.5rem;
    }
  }
</style>
