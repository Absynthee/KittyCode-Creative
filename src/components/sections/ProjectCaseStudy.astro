---
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import Button from "@/components/ui/Button.astro";
import Breadcrumbs from "@/components/ui/Breadcrumbs.astro";
import { ArrowLeft, ArrowRight, ExternalLink } from "@lucide/astro";

interface Props {
  entry: CollectionEntry<"projects">;
  prev?: CollectionEntry<"projects"> | null;
  next?: CollectionEntry<"projects"> | null;
}

const { entry, prev, next } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);
---

<section class="section case-study">
  <Breadcrumbs
    class="case-breadcrumbs"
    items={[
      { name: "Home", href: "/" },
      { name: "Portfolio", href: "/portfolio" },
      { name: data.title },
    ]}
  />

  <figure class="case-cover">
    <Image
      src={data.cover}
      alt={data.coverAlt || `The ${data.title} website`}
      width={1200}
      height={800}
      loading="eager"
    />
  </figure>

  <div class="case-layout">
    <aside class="case-meta">
      <dl>
        <div class="meta-row">
          <dt>Client</dt>
          <dd>{data.client}</dd>
        </div>
        {
          data.year && (
            <div class="meta-row">
              <dt>Year</dt>
              <dd>{data.year}</dd>
            </div>
          )
        }
        {
          data.services.length > 0 && (
            <div class="meta-row">
              <dt>Services</dt>
              <dd>{data.services.join(", ")}</dd>
            </div>
          )
        }
        {
          data.tech.length > 0 && (
            <div class="meta-row">
              <dt>Built with</dt>
              <dd>{data.tech.join(", ")}</dd>
            </div>
          )
        }
      </dl>

      {
        data.tags.length > 0 && (
          <ul class="case-tags" role="list">
            {data.tags.map((tag) => (
              <li class="tag">{tag}</li>
            ))}
          </ul>
        )
      }

      {
        data.liveUrl && (
          <a
            class="case-visit"
            href={data.liveUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Visit live site <ExternalLink size={16} aria-hidden="true" />
          </a>
        )
      }
    </aside>

    <div class="prose case-prose">
      <Content />
      {
        data.testimonial && (
          <blockquote class="case-quote">
            <p>{data.testimonial.quote}</p>
            <cite>{data.testimonial.author}</cite>
          </blockquote>
        )
      }
    </div>
  </div>

  <div class="case-actions">
    {
      data.liveUrl && (
        <Button
          href={data.liveUrl}
          variant="primary"
          size="large"
          target="_blank"
        >
          Visit Live Site
        </Button>
      )
    }
    <Button href="/contact" variant="outline" size="large">
      Start Your Project
    </Button>
  </div>

  <nav class="case-nav" aria-label="More projects">
    {
      prev ? (
        <a class="case-nav-link prev" href={`/portfolio/${prev.id}`}>
          <ArrowLeft size={18} aria-hidden="true" />
          <span>
            <span class="case-nav-label">Previous</span>
            {prev.data.title}
          </span>
        </a>
      ) : (
        <span />
      )
    }
    <a class="case-nav-all" href="/portfolio">All projects</a>
    {
      next ? (
        <a class="case-nav-link next" href={`/portfolio/${next.id}`}>
          <span>
            <span class="case-nav-label">Next</span>
            {next.data.title}
          </span>
          <ArrowRight size={18} aria-hidden="true" />
        </a>
      ) : (
        <span />
      )
    }
  </nav>
</section>

<style>
  .case-study {
    text-align: start;
  }

  .case-breadcrumbs {
    max-inline-size: 1100px;
  }

  /* Cover image */
  .case-cover {
    inline-size: 100%;
    max-inline-size: 1100px;
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid hsl(from var(--border) h s l / 0.2);
  }

  .case-cover img {
    inline-size: 100%;
    block-size: auto;
    object-fit: cover;
  }

  /* Two-column body */
  .case-layout {
    inline-size: 100%;
    max-inline-size: 1100px;
    display: grid;
    grid-template-columns: minmax(0, 17rem) minmax(0, 1fr);
    gap: var(--space-xl);
    align-items: start;
  }

  .case-meta {
    position: sticky;
    inset-block-start: 6rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    padding: var(--space-m);
    background: hsl(from var(--card) h s l / 0.05);
    border: 1px solid hsl(from var(--border) h s l / 0.2);
    border-radius: var(--radius);
  }

  .case-meta dl {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .meta-row {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .meta-row dt {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    color: hsl(from var(--foreground) h s l / 0.55);
  }

  .meta-row dd {
    margin: 0;
    font-size: var(--step--1);
    color: var(--foreground);
  }

  .case-tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .case-visit {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 600;
    font-size: var(--step--1);
    color: var(--primary);
    text-decoration: none;
  }

  .case-visit:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Prose column: left-aligned within its grid track */
  .case-prose {
    margin-inline: 0;
    max-inline-size: 74ch;
  }

  .case-quote {
    font-style: normal;
  }

  .case-quote cite {
    display: block;
    margin-block-start: var(--space-xs);
    font-style: normal;
    font-weight: 600;
    color: var(--primary);
  }

  .case-quote cite::before {
    content: "— ";
  }

  /* Actions */
  .case-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  /* Prev / next */
  .case-nav {
    inline-size: 100%;
    max-inline-size: 1100px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-m);
    padding-block-start: var(--space-l);
    border-block-start: 1px solid hsl(from var(--border) h s l / 0.15);
  }

  .case-nav-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    min-inline-size: 0;
    text-decoration: none;
    color: var(--foreground);
    font-weight: 600;
    transition: color 0.2s ease;
    /* Override the global `main a { margin-block-end }`. */
    margin-block-end: 0;
  }

  .case-nav-link.prev {
    justify-self: start;
  }

  .case-nav-link.next {
    justify-self: end;
    text-align: end;
  }

  .case-nav-link:hover {
    color: var(--primary);
  }

  .case-nav-label {
    display: block;
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
    color: hsl(from var(--foreground) h s l / 0.7);
  }

  .case-nav-all {
    justify-self: center;
    font-size: var(--step--1);
    font-weight: 500;
    color: hsl(from var(--foreground) h s l / 0.7);
    text-decoration: none;
    white-space: nowrap;
    margin-block-end: 0;
  }

  .case-nav-all:hover {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 860px) {
    .case-layout {
      grid-template-columns: 1fr;
      gap: var(--space-l);
    }

    .case-meta {
      position: static;
    }
  }

  @media (max-width: 560px) {
    .case-nav {
      display: flex;
      justify-content: space-between;
      gap: var(--space-s);
    }

    .case-nav-all {
      display: none;
    }
  }
</style>
