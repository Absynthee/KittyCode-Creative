---
import Button from "@/components/ui/Button.astro";
import Input from "@/components/ui/Input.astro";
import Label from "@/components/ui/Label.astro";
import Textarea from "@/components/ui/Textarea.astro";
import Checkbox from "@/components/ui/Checkbox.astro";
import Radio from "@/components/ui/Radio.astro";
import { abs } from "@/lib/schema";

interface Props {
  /** Web3Forms access key */
  accessKey?: string;
  variant?:
    | "default"
    | "primary"
    | "secondary"
    | "info"
    | "success"
    | "warning"
    | "error";
  size?: "small" | "medium" | "large";
}

const {
  accessKey = "34317982-f38f-4672-b238-073c162f37c4",
  variant = "primary",
  size = "medium",
} = Astro.props;

const extras = [
  "Blog",
  "Google/Facebook Testimonials",
  "E-commerce",
  "Contact Form",
];

const styles = [
  "Corporate",
  "Professional",
  "Approachable",
  "Calm",
  "Friendly",
  "Playful",
  "Stylish",
];

const pageCounts = ["1-3", "4-10", "11-50", "50+"];
---

<div class="questionnaire-form">
  <form
    action="https://api.web3forms.com/submit"
    method="POST"
    class="questionnaire-form-inner"
    novalidate
  >
    <input type="hidden" name="access_key" value={accessKey} />
    <input type="hidden" name="subject" value="Website Questionnaire" />
    <input type="hidden" name="from_name" value="KittyCode Creative Website" />
    {/* No-JS fallback: Web3Forms redirects here after a native POST */}
    <input type="hidden" name="redirect" value={abs("/thank-you")} />

    <h3 class="questionnaire-heading">Your Details</h3>
    <div class="questionnaire-fields">
      <fieldset class="questionnaire-field">
        <Label htmlFor="q-name" variant={variant} size={size} required>
          Your Name
        </Label>
        <Input
          id="q-name"
          name="name"
          type="text"
          placeholder="Sir Pawsworth III"
          autocomplete="name"
          variant={variant}
          size={size}
          required
        />
      </fieldset>

      <fieldset class="questionnaire-field">
        <Label htmlFor="q-business-name" variant={variant} size={size} required>
          Business Name
        </Label>
        <Input
          id="q-business-name"
          name="Business Name"
          type="text"
          placeholder="KittyCode Creative"
          autocomplete="organization"
          variant={variant}
          size={size}
          required
        />
      </fieldset>

      <fieldset class="questionnaire-field questionnaire-field--full">
        <Label htmlFor="q-email" variant={variant} size={size} required>
          Email Address
        </Label>
        <Input
          id="q-email"
          name="email"
          type="email"
          placeholder="meow@kittycodecreative.com"
          autocomplete="email"
          variant={variant}
          size={size}
          required
        />
      </fieldset>
    </div>

    <h3 class="questionnaire-heading">Business Details</h3>
    <div class="questionnaire-fields">
      <fieldset class="questionnaire-field">
        <Label
          htmlFor="q-business-about"
          variant={variant}
          size={size}
          required
        >
          What does your business do?
        </Label>
        <Textarea
          id="q-business-about"
          name="What does your business do?"
          placeholder="Your industry and goals."
          variant={variant}
          size={size}
          rows={4}
          required
          autoResize={true}
        />
      </fieldset>

      <fieldset class="questionnaire-field">
        <Label
          htmlFor="q-existing-website"
          variant={variant}
          size={size}
          required
        >
          Do you already have a website?
        </Label>
        <Textarea
          id="q-existing-website"
          name="Do you already have a website?"
          placeholder="If so, please leave a link to the existing website."
          variant={variant}
          size={size}
          rows={4}
          required
          autoResize={true}
        />
      </fieldset>

      <fieldset class="questionnaire-field">
        <Label htmlFor="q-customers" variant={variant} size={size} required>
          Who are your potential customers?
        </Label>
        <Textarea
          id="q-customers"
          name="Who are your potential customers?"
          placeholder="Age range, location, interests, and so on."
          variant={variant}
          size={size}
          rows={4}
          required
          autoResize={true}
        />
      </fieldset>

      <fieldset class="questionnaire-field">
        <Label
          htmlFor="q-differentiators"
          variant={variant}
          size={size}
          required
        >
          How does your business differ from competitors?
        </Label>
        <Textarea
          id="q-differentiators"
          name="How does your business differ from competitors?"
          placeholder="What do you do differently? How do you market yourself in a way that's better than others?"
          variant={variant}
          size={size}
          rows={4}
          required
          autoResize={true}
        />
      </fieldset>

      <fieldset class="questionnaire-field questionnaire-field--full">
        <Label htmlFor="q-competitors" variant={variant} size={size} required>
          Who are your main competitors?
        </Label>
        <Textarea
          id="q-competitors"
          name="Who are your main competitors?"
          placeholder="Similar businesses in your industry. Researching competitors helps us design an appropriate website for you."
          variant={variant}
          size={size}
          rows={4}
          required
          autoResize={true}
        />
      </fieldset>
    </div>

    <h3 class="questionnaire-heading">Website Details</h3>
    <div class="questionnaire-fields">
      <fieldset class="questionnaire-field">
        <Label htmlFor="q-purpose" variant={variant} size={size} required>
          What is the website's main purpose?
        </Label>
        <Textarea
          id="q-purpose"
          name="What is the website's purpose?"
          placeholder="Try to summarise the goal of your website and what you want it to achieve."
          variant={variant}
          size={size}
          rows={4}
          required
          autoResize={true}
        />
      </fieldset>

      <fieldset class="questionnaire-field">
        <Label htmlFor="q-logo" variant={variant} size={size} required>
          Do you already have a logo for your brand?
        </Label>
        <Textarea
          id="q-logo"
          name="Do you have a logo?"
          placeholder="If not, will you need a logo as well?"
          variant={variant}
          size={size}
          rows={4}
          required
          autoResize={true}
        />
      </fieldset>

      <fieldset class="questionnaire-field">
        <Label htmlFor="q-content" variant={variant} size={size} required>
          Do you have content ready for your website?
        </Label>
        <Textarea
          id="q-content"
          name="Do you have website content ready?"
          placeholder="The text and images you are putting on the website."
          variant={variant}
          size={size}
          rows={4}
          required
          autoResize={true}
        />
      </fieldset>

      <fieldset class="questionnaire-field">
        <Label htmlFor="q-hosting" variant={variant} size={size} required>
          Will you require hosting?
        </Label>
        <Textarea
          id="q-hosting"
          name="Will you require hosting?"
          placeholder="Hosting is included in all of our monthly packages. Otherwise, we will look at a one-off cost."
          variant={variant}
          size={size}
          rows={4}
          required
          autoResize={true}
        />
      </fieldset>
    </div>

    <h4 class="questionnaire-subheading">
      Please share 3 websites you like the look of:
    </h4>
    <div class="questionnaire-fields questionnaire-fields--thirds">
      {
        [1, 2, 3].map((n) => (
          <fieldset class="questionnaire-field">
            <Label
              htmlFor={`q-website-like-${n}`}
              variant={variant}
              size={size}
              required
            >
              Website {n}
            </Label>
            <Input
              id={`q-website-like-${n}`}
              name={`Website ${n}`}
              type="text"
              placeholder={`https://website-${n}.com`}
              variant={variant}
              size={size}
              required
            />
          </fieldset>
        ))
      }
    </div>

    <fieldset class="questionnaire-options">
      <legend class="questionnaire-subheading">
        Do you need any of the following?
      </legend>
      <div class="questionnaire-choices">
        {
          extras.map((extra) => (
            <Checkbox
              name="Website Extras"
              value={extra}
              variant={variant}
              size={size}
            >
              {extra}
            </Checkbox>
          ))
        }
      </div>
    </fieldset>

    <fieldset class="questionnaire-options">
      <legend class="questionnaire-subheading">
        What kind of style or feel would you like your website to portray?
      </legend>
      <div class="questionnaire-choices">
        {
          styles.map((style) => (
            <Checkbox
              name="Website Style"
              value={style}
              variant={variant}
              size={size}
            >
              {style}
            </Checkbox>
          ))
        }
      </div>
    </fieldset>

    <fieldset class="questionnaire-options">
      <legend class="questionnaire-subheading">
        How many pages do you think your website will need?
      </legend>
      <div class="questionnaire-choices">
        {
          pageCounts.map((count) => (
            <Radio
              name="How many pages?"
              value={count}
              checked={count === "1-3"}
              variant={variant}
              size={size}
            >
              {count}
            </Radio>
          ))
        }
      </div>
    </fieldset>

    <div class="questionnaire-fields">
      <fieldset class="questionnaire-field">
        <Label htmlFor="q-brand-guide" variant={variant} size={size} required>
          Does your business have a brand guide?
        </Label>
        <Textarea
          id="q-brand-guide"
          name="Brand Guide"
          placeholder="Any brand guide, style guide or design system that will aid in the consistency of design across your brand."
          variant={variant}
          size={size}
          rows={4}
          required
          autoResize={true}
        />
      </fieldset>

      <fieldset class="questionnaire-field">
        <Label htmlFor="q-seo" variant={variant} size={size} required>
          Is it vital to be found on the first page of Google?
        </Label>
        <Textarea
          id="q-seo"
          name="SEO ranking"
          placeholder="How important is SEO for your business?"
          variant={variant}
          size={size}
          rows={4}
          required
          autoResize={true}
        />
      </fieldset>

      <fieldset class="questionnaire-field">
        <Label htmlFor="q-launch-date" variant={variant} size={size} required>
          Do you have an ideal launch date?
        </Label>
        <Textarea
          id="q-launch-date"
          name="Website launch date"
          placeholder="This can help us with time management of the project."
          variant={variant}
          size={size}
          rows={4}
          required
          autoResize={true}
        />
      </fieldset>

      <fieldset class="questionnaire-field">
        <Label htmlFor="q-budget" variant={variant} size={size} required>
          What is your budget?
        </Label>
        <Textarea
          id="q-budget"
          name="What is your budget?"
          placeholder="What is your budget for the project?"
          variant={variant}
          size={size}
          rows={4}
          required
          autoResize={true}
        />
      </fieldset>

      <fieldset class="questionnaire-field questionnaire-field--full">
        <Label htmlFor="q-extra-info" variant={variant} size={size}>
          Anything else you feel might be important?
        </Label>
        <Textarea
          id="q-extra-info"
          name="Extra information"
          placeholder="Anything that isn't mentioned in the other sections, or something you want to expand on. (optional)"
          variant={variant}
          size={size}
          rows={5}
          autoResize={true}
        />
      </fieldset>
    </div>

    {/* Honeypot field for spam bots */}
    <input
      type="checkbox"
      name="botcheck"
      class="botcheck"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
    />

    <div class="questionnaire-actions">
      <Button type="submit" variant={variant} size={size}>
        Submit Questionnaire
      </Button>
    </div>

    <p class="form-status" role="status" aria-live="polite"></p>
  </form>
</div>

<script>
  import {
    getHTMLElements,
    getHTMLElement,
    findElements,
    addElementClass,
    removeElementClass,
    isInputElement,
    isTextAreaElement,
    getFormValue,
  } from "@/lib/utils";

  document.addEventListener("astro:page-load", () => {
    const questionnaireForms = getHTMLElements(".questionnaire-form");

    questionnaireForms.forEach((wrapper) => {
      const form = getHTMLElement("form", wrapper) as HTMLFormElement | null;
      if (!form) return;

      const inputs = findElements(
        "input[required], textarea[required]",
        wrapper,
      );
      const status = getHTMLElement(".form-status", wrapper);

      inputs.forEach((input) => {
        input.addEventListener("blur", validateField);
        input.addEventListener("input", clearErrorOnInput);
      });

      form.addEventListener("submit", handleSubmit);

      function getFieldError(
        input: HTMLInputElement | HTMLTextAreaElement,
      ): string | null {
        const value = getFormValue(input);
        if (input.required && !value.trim()) {
          return `${getLabelText(input)} is required`;
        }
        if (value.trim() && input.type === "email") {
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          if (!emailRegex.test(value)) {
            return "Please enter a valid email address";
          }
        }
        return null;
      }

      function getLabelText(
        input: HTMLInputElement | HTMLTextAreaElement,
      ): string {
        const label = getHTMLElement(`label[for="${input.id}"]`, wrapper);
        return label
          ? label.textContent?.replace("*", "").trim() || "Field"
          : "Field";
      }

      function validateField(event: Event) {
        const input = event.target;
        if (!isInputElement(input) && !isTextAreaElement(input)) return;
        const field = input.closest(".questionnaire-field") as HTMLElement;
        if (!field) return;
        clearErrors(field);
        const error = getFieldError(input);
        if (error) showError(field, error);
      }

      function clearErrorOnInput(event: Event) {
        const input = event.target;
        if (!isInputElement(input) && !isTextAreaElement(input)) return;
        const field = input.closest(".questionnaire-field") as HTMLElement;
        if (!field) return;
        if (
          getFormValue(input).trim() &&
          field.classList.contains("field--error")
        ) {
          clearErrors(field);
        }
      }

      function showError(field: HTMLElement, message: string) {
        addElementClass(field, "field--error");
        let errorEl = getHTMLElement(".error-message", field);
        if (!errorEl) {
          errorEl = document.createElement("span");
          addElementClass(errorEl, "error-message");
          field.appendChild(errorEl);
        }
        errorEl.textContent = message;
      }

      function clearErrors(field: HTMLElement) {
        removeElementClass(field, "field--error");
        const errorEl = getHTMLElement(".error-message", field);
        if (errorEl) errorEl.remove();
      }

      async function handleSubmit(event: Event) {
        event.preventDefault();
        let hasErrors = false;

        inputs.forEach((input) => {
          if (!isInputElement(input) && !isTextAreaElement(input)) return;
          const field = input.closest(".questionnaire-field") as HTMLElement;
          if (!field) return;
          clearErrors(field);
          const error = getFieldError(input);
          if (error) {
            showError(field, error);
            hasErrors = true;
          }
        });

        if (hasErrors) {
          const firstError = wrapper.querySelector(
            ".field--error input, .field--error textarea",
          ) as HTMLElement | null;
          firstError?.focus();
          if (status) {
            status.textContent =
              "Some required fields are missing. Please check the form above.";
            status.className = "form-status form-status--error";
          }
          return;
        }

        if (!form) return;
        const submitBtn = form.querySelector(
          "button[type='submit']",
        ) as HTMLButtonElement | null;

        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = "Sending…";
        }
        if (status) {
          status.textContent = "";
          status.className = "form-status";
        }

        try {
          const formData = new FormData(form);
          // The redirect field is only for the no-JS fallback; with fetch we
          // navigate ourselves so Web3Forms returns JSON instead.
          formData.delete("redirect");

          const response = await fetch(form.action, {
            method: "POST",
            body: formData,
            headers: { Accept: "application/json" },
          });
          const data = await response.json();

          if (response.ok && data.success) {
            window.location.href = "/thank-you";
          } else {
            throw new Error(data.message || "Submission failed");
          }
        } catch (error) {
          if (status) {
            status.textContent =
              "Something went wrong. Please try again, or email hello@kittycodecreative.com.";
            status.classList.add("form-status--error");
          }
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = "Submit Questionnaire";
          }
        }
      }
    });
  });
</script>

<style>
  .questionnaire-form {
    max-inline-size: calc(1000px + 4rem);
    margin: 0 auto;
    inline-size: 100%;
    padding-inline: 1rem;
  }

  .questionnaire-form-inner {
    padding: 2rem;
    background: hsl(from var(--card) h s l / 0.05);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    backdrop-filter: blur(8px);
    position: relative;
    overflow: hidden;
    transition: all ease-in-out 0.5s;
  }

  .questionnaire-form-inner::before {
    content: "";
    position: absolute;
    inset-block-start: 0;
    inset-inline-start: 0;
    inset-inline-end: 0;
    block-size: 4px;
    background: linear-gradient(
      90deg,
      var(--primary),
      var(--primary),
      var(--info),
      var(--success),
      var(--primary)
    );
    background-size: 200% 100%;
    animation: shimmer 30s ease-in-out infinite;
  }

  @keyframes shimmer {
    0%,
    100% {
      background-position: -200% 0;
    }
    50% {
      background-position: 200% 0;
    }
  }

  .questionnaire-form-inner:hover {
    border-color: hsl(from var(--primary) h s l / 0.3);
    box-shadow: 0 4px 20px hsl(from var(--primary) h s l / 0.1);
  }

  .questionnaire-heading {
    margin-block: 2rem 1.5rem;
    position: relative;
    z-index: 1;
  }

  .questionnaire-heading:first-of-type {
    margin-block-start: 0;
  }

  .questionnaire-subheading {
    margin-block: 1.5rem 1rem;
    font-size: var(--step-0);
    position: relative;
    z-index: 1;
  }

  .questionnaire-fields {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-block-end: 2rem;
    position: relative;
    z-index: 1;
  }

  .questionnaire-fields--thirds {
    grid-template-columns: repeat(3, 1fr);
  }

  .questionnaire-field {
    border: none;
    padding: 0;
    margin: 0;
    min-inline-size: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    transition: transform 0.2s ease;
  }

  .questionnaire-field:focus-within {
    transform: translateY(-1px);
  }

  .questionnaire-field--full {
    grid-column: 1 / -1;
  }

  .questionnaire-options {
    border: none;
    padding: 0;
    margin: 0;
    margin-block-end: 2rem;
    position: relative;
    z-index: 1;
  }

  .questionnaire-options .questionnaire-subheading {
    margin-block-start: 0;
  }

  .questionnaire-choices {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
  }

  .questionnaire-actions {
    display: flex;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .botcheck {
    position: absolute !important;
    inline-size: 1px;
    block-size: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .error-message {
    font-size: var(--step--2);
    color: var(--error);
    margin-block-start: 0.25rem;
    display: block;
    font-weight: 500;
    animation: slideInDown 0.3s ease;
  }

  .form-status {
    margin-block-start: 1.5rem;
    text-align: center;
    font-weight: 500;
    position: relative;
    z-index: 1;
  }

  .form-status:empty {
    display: none;
  }

  .form-status--success {
    color: var(--success);
  }

  .form-status--error {
    color: var(--error);
  }

  @keyframes slideInDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 768px) {
    .questionnaire-form {
      margin: 0;
      padding-inline: 0;
    }

    .questionnaire-form-inner {
      padding: 1.5rem 1rem;
    }

    .questionnaire-form-inner::before {
      animation: none;
    }

    .questionnaire-fields,
    .questionnaire-fields--thirds {
      grid-template-columns: 1fr;
    }

    .questionnaire-actions :global(.btn) {
      inline-size: 100%;
    }
  }
</style>
