---
import Button from "@/components/ui/Button.astro";
import Switch from "@/components/ui/Switch.astro";
import { Check } from "@lucide/astro";

interface Plan {
  name: string;
  monthly: string;
  oneOff: string;
  features: string[];
  monthlyTerm: string;
  oneOffTerm: string;
  designFee: string;
  recommended?: boolean;
}

interface Props {
  plans?: Plan[];
  cta?: { text: string; href: string };
}

const {
  plans = [
    {
      name: "Standard",
      monthly: "£40",
      oneOff: "£650",
      features: [
        "1–3 page website",
        "Hosting included",
        "Enhanced security",
        "10,000 monthly visits",
        "Secure SSL",
        "Perfect for individuals",
      ],
      monthlyTerm: "12 month contract",
      oneOffTerm: "50% deposit required",
      designFee: "£300",
    },
    {
      name: "Premium",
      monthly: "£75",
      oneOff: "£2000",
      features: [
        "4–10 page website",
        "Hosting included",
        "Unlimited updates",
        "100,000 monthly visits",
        "Secure SSL",
        "Best for startups",
      ],
      monthlyTerm: "24 month contract",
      oneOffTerm: "50% deposit required",
      designFee: "£450",
      recommended: true,
    },
    {
      name: "Premium+",
      monthly: "£100",
      oneOff: "£3000",
      features: [
        "Up to 100 pages",
        "CMS content & blog pages",
        "Increased hosting speed",
        "1,000,000 monthly visits",
        "Priority edits & updates",
        "Perfect for small businesses",
      ],
      monthlyTerm: "24 month contract",
      oneOffTerm: "50% deposit required",
      designFee: "£750",
    },
  ],
  cta = { text: "Get Started", href: "/#contact" },
} = Astro.props;
---

<div class="pricing" data-billing="monthly">
  <div class="billing-toggle" role="group" aria-label="Choose billing period">
    <span class="billing-option billing-monthly">Monthly</span>
    <Switch
      variant="primary"
      size="large"
      name="billing"
      class="billing-switch"
    >
      <span class="sr-only">Toggle between monthly and one-off pricing</span>
    </Switch>
    <span class="billing-option billing-oneoff">One-off</span>
  </div>

  <ul class="plans" role="list">
    {
      plans.map((plan, index) => (
        <li
          class:list={["plan", { "plan--recommended": plan.recommended }]}
          style={`--delay: ${index * 0.1}s`}
        >
          {plan.recommended && <span class="plan-badge">Recommended</span>}
          <div class="plan-header">
            <h3 class="plan-name">{plan.name}</h3>
            <p class="plan-price">
              <span class="price-monthly">
                {plan.monthly}
                <span class="price-period">/month</span>
              </span>
              <span class="price-oneoff">{plan.oneOff}</span>
            </p>
          </div>

          <ul class="plan-features" role="list">
            {plan.features.map((feature) => (
              <li>
                <Check size={18} aria-hidden="true" />
                <span>{feature}</span>
              </li>
            ))}
          </ul>

          <div class="plan-terms">
            <p class="term-monthly">{plan.monthlyTerm}</p>
            <p class="term-oneoff">{plan.oneOffTerm}</p>
            <p class="term-fee">
              <strong>{plan.designFee}</strong> initial design fee applies
            </p>
          </div>

          <Button
            href={cta.href}
            variant={plan.recommended ? "primary" : "outline"}
            size="medium"
            class="plan-cta"
          >
            {cta.text}
          </Button>
        </li>
      ))
    }
  </ul>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const pricing = document.querySelector<HTMLElement>(".pricing");
    if (!pricing) return;

    const input = pricing.querySelector<HTMLInputElement>(
      ".billing-switch input[type='checkbox']",
    );
    if (!input) return;

    const update = () => {
      pricing.dataset.billing = input.checked ? "oneoff" : "monthly";
    };

    update();
    input.addEventListener("change", update);
  });
</script>

<style>
  .pricing {
    inline-size: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-l);
  }

  /* Billing toggle */
  .billing-toggle {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .billing-option {
    font-size: var(--step-0);
    font-weight: 600;
    color: hsl(from var(--foreground) h s l / 0.5);
    transition: color 0.2s ease;
  }

  .pricing[data-billing="monthly"] .billing-monthly,
  .pricing[data-billing="oneoff"] .billing-oneoff {
    color: var(--primary);
  }

  /* Plans grid */
  .plans {
    list-style: none;
    margin: 0;
    padding: 0;
    inline-size: 100%;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: stretch;
  }

  .plan {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    padding: var(--space-l);
    background: hsl(from var(--card) h s l / 0.05);
    border: 1px solid hsl(from var(--border) h s l / 0.2);
    border-radius: var(--radius);
    backdrop-filter: blur(8px);
    position: relative;
    transition: all 0.3s ease;
    animation: fadeInUp 0.6s ease-out var(--delay) both;
  }

  .plan:hover {
    border-color: hsl(from var(--primary) h s l / 0.4);
    box-shadow: 0 4px 20px hsl(from var(--primary) h s l / 0.1);
  }

  .plan--recommended {
    border-color: var(--primary);
    box-shadow: 0 4px 24px hsl(from var(--primary) h s l / 0.15);
  }

  .plan-badge {
    position: absolute;
    inset-block-start: 0;
    inset-inline-start: 50%;
    transform: translate(-50%, -50%);
    background: var(--primary);
    color: var(--primary-foreground, var(--white));
    font-size: var(--step--2);
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    white-space: nowrap;
  }

  .plan-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-block-end: var(--space-s);
    border-block-end: 1px solid hsl(from var(--border) h s l / 0.2);
  }

  .plan-name {
    font-size: var(--step-1);
    text-transform: capitalize;
  }

  .plan-price {
    font-size: var(--step-4);
    font-weight: 700;
    color: var(--primary);
    line-height: 1;
  }

  .price-period {
    font-size: var(--step-0);
    font-weight: 500;
    color: hsl(from var(--foreground) h s l / 0.6);
  }

  /* Toggle price display */
  .price-oneoff,
  .term-oneoff {
    display: none;
  }

  .pricing[data-billing="oneoff"] .price-monthly,
  .pricing[data-billing="oneoff"] .term-monthly {
    display: none;
  }

  .pricing[data-billing="oneoff"] .price-oneoff,
  .pricing[data-billing="oneoff"] .term-oneoff {
    display: inline;
  }

  .plan-features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .plan-features li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--step--1);
    color: hsl(from var(--foreground) h s l / 0.85);
  }

  .plan-features :global(svg) {
    color: var(--primary);
    flex-shrink: 0;
  }

  .plan-terms {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: var(--step--2);
    color: hsl(from var(--foreground) h s l / 0.6);
  }

  .term-fee strong {
    color: hsl(from var(--foreground) h s l / 0.85);
  }

  .plan-cta {
    inline-size: 100%;
  }

  .sr-only {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 900px) {
    .plans {
      grid-template-columns: 1fr;
      max-inline-size: 28rem;
      margin: 0 auto;
    }
  }
</style>
