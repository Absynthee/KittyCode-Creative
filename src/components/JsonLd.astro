---
// Renders a JSON-LD structured-data block. Replaces the repeated
// `<script is:inline type="application/ld+json" set:html={...}>` on every page.
interface Props {
  data: unknown;
}

const { data } = Astro.props;
---

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(data)}
/>
