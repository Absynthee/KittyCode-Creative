---
interface Props {
  value: string;
  class?: string;
}

const { value, class: className = "" } = Astro.props;
---

<div class={`accordion-item ${className}`} data-value={value}>
  <slot />
</div>

<style>
  .accordion-item {
    border-block-end: 1px solid var(--border);
  }

  .accordion-item:last-child {
    border-block-end: none;
  }

  .accordion-item[data-open] {
    border-inline-start: 2px solid var(--primary-absolute);
  }
</style>
