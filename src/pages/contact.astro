---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/sections/PageHero.astro";
import ContactMethods from "@/components/sections/ContactMethods.astro";
import ContactForm from "@/components/sections/ContactForm.astro";
import FaqSection from "@/components/sections/FaqSection.astro";
import JsonLd from "@/components/JsonLd.astro";
import { SITE_URL as siteUrl, breadcrumbs } from "@/lib/schema";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ContactPage",
      "@id": `${siteUrl}/contact#webpage`,
      url: `${siteUrl}/contact`,
      name: "Contact KittyCode Creative",
      description:
        "Get in touch with KittyCode Creative, a bespoke web design agency in Eastbourne. Email us or send an enquiry and we'll reply within one working day.",
      isPartOf: { "@id": `${siteUrl}/#website` },
      about: { "@id": `${siteUrl}/#organization` },
    },
    breadcrumbs([{ name: "Contact", path: "/contact" }]),
  ],
};
---

<Layout
  title="Contact Us"
  description="Get in touch with KittyCode Creative, a bespoke web design agency in Eastbourne. Email hello@kittycodecreative.com or send us an enquiry and we'll reply within one working day."
>
  <PageHero
    eyebrow="let's talk"
    title="Contact Us"
    lead="Tell us about your project, ask a question, or just say hello. However you choose to reach out, we aim to get back to you as soon as we can."
    primaryCTA={{ text: "Send a Message", href: "#enquiry" }}
    secondaryCTA={{ text: "View Pricing", href: "/services" }}
  />

  <ContactMethods />

  <section id="enquiry" class="section">
    <mark>send us a message</mark>
    <h2>Start the Conversation</h2>
    <p>
      Fill in the form below and we'll be in touch. Prefer email? Reach us any
      time at <a href="mailto:hello@kittycodecreative.com"
        >hello@kittycodecreative.com</a
      >. Planning a new website? Get a head-start by filling in our <a
        href="/services/website-questionnaire">website questionnaire</a
      >.
    </p>
    <ContactForm />
  </section>

  <FaqSection />

  <JsonLd data={structuredData} />
</Layout>
