---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/sections/PageHero.astro";
import ServicesIntro from "@/components/sections/ServicesIntro.astro";
import FeaturesSection from "@/components/sections/FeaturesSection.astro";
import ProcessSection from "@/components/sections/ProcessSection.astro";
import PricingSection from "@/components/sections/PricingSection.astro";
import FaqSection from "@/components/sections/FaqSection.astro";
import CallToAction from "@/components/sections/CallToAction.astro";
import JsonLd from "@/components/JsonLd.astro";
import { SITE_URL as siteUrl, breadcrumbs } from "@/lib/schema";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "@id": `${siteUrl}/services#service`,
      serviceType: "Web Design & Development",
      name: "Bespoke Web Design & Development",
      url: `${siteUrl}/services`,
      description:
        "Hand-coded, bespoke web design and front-end development for individuals and small businesses. Every website is responsive, WCAG accessible and includes SEO and hosting.",
      provider: { "@id": `${siteUrl}/#organization` },
      areaServed: { "@type": "Country", name: "United Kingdom" },
      offers: [
        {
          "@type": "Offer",
          name: "Standard Website",
          description: "A 1–3 page bespoke website with hosting included.",
          price: "650",
          priceCurrency: "GBP",
        },
        {
          "@type": "Offer",
          name: "Premium Website",
          description: "A 4–10 page bespoke website with unlimited updates.",
          price: "2000",
          priceCurrency: "GBP",
        },
        {
          "@type": "Offer",
          name: "Premium+ Website",
          description: "Up to 100 pages with CMS, blog and priority support.",
          price: "3000",
          priceCurrency: "GBP",
        },
      ],
    },
    breadcrumbs([{ name: "Services", path: "/services" }]),
  ],
};
---

<Layout
  title="Web Design & Development"
  description="Bespoke, hand-coded web design and front-end development in Eastbourne. Fast, accessible, responsive websites with SEO and hosting included. Simple, transparent pricing."
>
  <PageHero
    eyebrow="feline creative?"
    title="Web Design & Development"
    lead="We hand-code beautiful, fast, accessible websites from scratch, so your site is unmistakably yours and built to perform. SEO and hosting are included as standard."
    primaryCTA={{ text: "Get a Free Quote", href: "/contact" }}
    secondaryCTA={{ text: "View Pricing", href: "#services" }}
  />

  <ServicesIntro />
  <FeaturesSection />
  <ProcessSection />
  <PricingSection cta={{ text: "Get Started", href: "/contact" }} />
  <FaqSection />

  <CallToAction
    primaryCTA={{ text: "Get a Free Quote", href: "/contact" }}
    secondaryCTA={{ text: "See Our Work", href: "/portfolio" }}
  />

  <JsonLd data={structuredData} />
</Layout>
