---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/sections/PageHero.astro";
import AboutStory from "@/components/sections/AboutStory.astro";
import ValuesGrid from "@/components/sections/ValuesGrid.astro";
import StatsSection from "@/components/sections/StatsSection.astro";
import ProcessSection from "@/components/sections/ProcessSection.astro";
import CallToAction from "@/components/sections/CallToAction.astro";
import JsonLd from "@/components/JsonLd.astro";
import { SITE_URL as siteUrl, breadcrumbs } from "@/lib/schema";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "AboutPage",
      "@id": `${siteUrl}/about#webpage`,
      url: `${siteUrl}/about`,
      name: "About KittyCode Creative",
      description:
        "Learn about KittyCode Creative, a bespoke web design and development agency based in Eastbourne, East Sussex. Discover our story, mission, values and approach.",
      about: { "@id": `${siteUrl}/#organization` },
      isPartOf: { "@id": `${siteUrl}/#website` },
    },
    {
      "@type": ["ProfessionalService", "WebDesignAgency"],
      "@id": `${siteUrl}/#organization`,
      name: "KittyCode Creative",
      url: siteUrl,
      email: "hello@kittycodecreative.com",
      foundingDate: "2024",
      founder: { "@type": "Person", name: "Austin Spillman" },
      description:
        "KittyCode Creative is a modern web design and development agency based in Eastbourne, East Sussex. We build bespoke, fully accessible (WCAG-compliant) and responsive websites from scratch for individuals and small businesses.",
      areaServed: { "@type": "Country", name: "United Kingdom" },
      address: {
        "@type": "PostalAddress",
        addressLocality: "Eastbourne",
        addressRegion: "East Sussex",
        addressCountry: "GB",
      },
    },
    breadcrumbs([{ name: "About", path: "/about" }]),
  ],
};
---

<Layout
  title="About Us"
  description="Meet KittyCode Creative, a bespoke web design agency in Eastbourne, East Sussex. Learn about our story, mission, values and hand-coded approach to accessible, responsive websites."
>
  <PageHero
    eyebrow="we're the cat's paw-jamas"
    title="About KittyCode Creative"
    lead="A modern web design and development agency based in Eastbourne, on a mission to give individuals and small businesses beautiful, accessible websites that are genuinely their own."
    primaryCTA={{ text: "Start Your Project", href: "/contact" }}
    secondaryCTA={{ text: "See Our Work", href: "/portfolio" }}
  />

  <AboutStory />
  <ValuesGrid />
  <StatsSection />
  <ProcessSection />

  <CallToAction
    primaryCTA={{ text: "Get a Free Quote", href: "/contact" }}
    secondaryCTA={{ text: "See Our Work", href: "/portfolio" }}
  />

  <JsonLd data={structuredData} />
</Layout>
