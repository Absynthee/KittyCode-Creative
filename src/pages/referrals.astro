---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/sections/PageHero.astro";
import ReferralSteps from "@/components/sections/ReferralSteps.astro";
import IconCardGrid from "@/components/ui/IconCardGrid.astro";
import CallToAction from "@/components/sections/CallToAction.astro";
import JsonLd from "@/components/JsonLd.astro";
import {
  Accordion,
  AccordionContent,
  AccordionTrigger,
  AccordionItem,
} from "@/components/ui/accordion/";
import { Percent, Infinity, Users, Wallet } from "@lucide/astro";
import { SITE_URL as siteUrl, breadcrumbs } from "@/lib/schema";

const perks = [
  {
    icon: Percent,
    title: "Real Money, Not Credit",
    body: "Your reward is 10% of your referral's first invoice, paid directly to you. No vouchers, no account credit, no catches.",
  },
  {
    icon: Infinity,
    title: "No Referral Limit",
    body: "There's no cap on how many people you can refer. Every successful referral earns you another 10%.",
  },
  {
    icon: Users,
    title: "Anyone Can Take Part",
    body: "You don't need to be a client to refer someone. If you know someone who needs a website, that's enough.",
  },
  {
    icon: Wallet,
    title: "Paid Promptly",
    body: "As soon as your referral pays their first invoice, we arrange your payment in whatever way suits you best.",
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${siteUrl}/referrals#webpage`,
      url: `${siteUrl}/referrals`,
      name: "Referral Programme",
      description:
        "Refer a friend to KittyCode Creative and earn 10% of their first project invoice. No limits, no catches, and you don't need to be a client to take part.",
      about: { "@id": `${siteUrl}/#organization` },
      isPartOf: { "@id": `${siteUrl}/#website` },
    },
    breadcrumbs([{ name: "Referrals", path: "/referrals" }]),
  ],
};
---

<Layout
  title="Referral Programme"
  description="Refer a friend to KittyCode Creative and earn 10% of their first invoice when they book a project. No limits, no catches, and you don't need to be a client to take part."
>
  <PageHero
    eyebrow="tell your fur-iends"
    title="Refer a Friend, Earn 10%"
    lead="Know someone who needs a website? Send them our way. When they book their first project with us, we'll send you 10% of their first invoice as a thank you."
    primaryCTA={{ text: "Refer Someone Now", href: "/contact" }}
    secondaryCTA={{ text: "View Our Services", href: "/services" }}
  />

  <ReferralSteps />

  <section id="perks" class="section" aria-labelledby="perks-title">
    <mark>the purr-ks</mark>
    <h2 id="perks-title">What's In It for You</h2>
    <p>
      We'd rather reward the people who recommend us than spend that money on
      advertising. It's as simple as that.
    </p>
    <IconCardGrid items={perks} columns={2} align="left" />
  </section>

  <section
    id="referral-faq"
    class="section"
    aria-labelledby="referral-faq-title"
  >
    <mark>the fine print</mark>
    <h2 id="referral-faq-title">Referral FAQs</h2>
    <p>
      The programme is deliberately simple, but here are the details in case
      you're wondering.
    </p>
    <Accordion defaultValue="who">
      <AccordionItem value="who">
        <AccordionTrigger>Who can refer someone?</AccordionTrigger>
        <AccordionContent>
          Anyone! You don't need to be an existing client, a business or
          anything else. If you know someone who needs a website and you point
          them our way, you're in.
        </AccordionContent>
      </AccordionItem>
      <AccordionItem value="how">
        <AccordionTrigger>How do I refer someone?</AccordionTrigger>
        <AccordionContent>
          Just tell them about us! When they fill in our contact form or email
          us, ask them to mention your name so we know who to thank. That's all
          it takes.
        </AccordionContent>
      </AccordionItem>
      <AccordionItem value="counts">
        <AccordionTrigger>What counts as a successful referral?</AccordionTrigger>
        <AccordionContent>
          A new client who mentions you when they first get in touch and then
          goes on to book a project with us. Once their first invoice is paid,
          your reward is confirmed.
        </AccordionContent>
      </AccordionItem>
      <AccordionItem value="paid">
        <AccordionTrigger>When and how do I get paid?</AccordionTrigger>
        <AccordionContent>
          Once your referral has paid their first invoice, we'll get in touch to
          arrange your payment in whatever way suits you best.
        </AccordionContent>
      </AccordionItem>
      <AccordionItem value="earn">
        <AccordionTrigger>How much can I earn?</AccordionTrigger>
        <AccordionContent>
          10% of your referral's first invoice, so the bigger their project, the
          bigger your reward. There's no limit on how many people you can refer
          either.
        </AccordionContent>
      </AccordionItem>
    </Accordion>
  </section>

  <CallToAction
    heading="Know someone who needs a website?"
    text="Point them our way and we'll take care of the rest. And if that someone is you, we'd love to hear about your project too."
    primaryCTA={{ text: "Get In Touch", href: "/contact" }}
    secondaryCTA={{ text: "See Our Work", href: "/portfolio" }}
  />

  <JsonLd data={structuredData} />
</Layout>
