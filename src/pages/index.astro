---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/sections/Hero.astro";
import TopBar from "@/components/ui/TopBar.astro";
import TrustStrip from "@/components/sections/TrustStrip.astro";
import StatsSection from "@/components/sections/StatsSection.astro";
import AboutSection from "@/components/sections/AboutSection.astro";
import FeaturesSection from "@/components/sections/FeaturesSection.astro";
import ProcessSection from "@/components/sections/ProcessSection.astro";
import PricingSection from "@/components/sections/PricingSection.astro";
import PortfolioSection from "@/components/sections/PortfolioSection.astro";
import TestimonialsSection from "@/components/sections/TestimonialsSection.astro";
import HighlightsSection from "@/components/sections/HighlightsSection.astro";
import FaqSection from "@/components/sections/FaqSection.astro";
import CallToAction from "@/components/sections/CallToAction.astro";
import ContactSection from "@/components/sections/ContactSection.astro";
import JsonLd from "@/components/JsonLd.astro";
import { SITE_URL as siteUrl } from "@/lib/schema";

// Structured data for search engines and AI / agentic crawlers
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["ProfessionalService", "WebDesignAgency"],
      "@id": `${siteUrl}/#organization`,
      name: "KittyCode Creative",
      url: siteUrl,
      email: "hello@kittycodecreative.com",
      description:
        "KittyCode Creative is a modern web design and development agency based in Eastbourne, East Sussex. We build bespoke, fully accessible (WCAG-compliant) and responsive websites from scratch for individuals and small businesses.",
      areaServed: { "@type": "Country", name: "United Kingdom" },
      address: {
        "@type": "PostalAddress",
        addressLocality: "Eastbourne",
        addressRegion: "East Sussex",
        addressCountry: "GB",
      },
      knowsAbout: [
        "Web Design",
        "Web Development",
        "Accessibility (WCAG)",
        "Responsive Design",
        "Search Engine Optimisation",
        "Front-end Development",
        "Search Engine Optimisation (SEO)",
        "Website Maintenance",
        "Website Hosting",
        "Generative Engine Optimisation (GEO)",
        "Generative AI for Web Design",
        "AI Optimisation (AIO)",
      ],
      sameAs: [
        "https://www.facebook.com/KittyCodeCreative",
        "https://www.linkedin.com/company/kittycode-creative",
        "https://x.com/KittyCodeCreate",
        "https://www.instagram.com/kittycode_creative",
      ],
      makesOffer: [
        {
          "@type": "Offer",
          name: "Standard Website",
          description: "A 1–3 page bespoke website with hosting included.",
          price: "900",
          priceCurrency: "GBP",
        },
        {
          "@type": "Offer",
          name: "Premium Website",
          description: "A 4–10 page bespoke website with unlimited updates.",
          price: "2400",
          priceCurrency: "GBP",
        },
        {
          "@type": "Offer",
          name: "Premium+ Website",
          description: "Up to 100 pages with CMS, blog and priority support.",
          price: "3750",
          priceCurrency: "GBP",
        },
      ],
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: siteUrl,
      name: "KittyCode Creative",
      publisher: { "@id": `${siteUrl}/#organization` },
    },
    {
      "@type": "FAQPage",
      "@id": `${siteUrl}/#faq`,
      mainEntity: [
        {
          "@type": "Question",
          name: "What services do you offer?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "We offer bespoke web design, front-end web development and SEO. Every website is hand-coded from scratch and built to be responsive, accessible and optimised for search engines.",
          },
        },
        {
          "@type": "Question",
          name: "Why should we choose you?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Our focus is on building accessible, responsive and user-friendly websites. We pride ourselves on attention to detail and a commitment to delivering high-quality, WCAG-compliant work.",
          },
        },
        {
          "@type": "Question",
          name: "Will I need to attend meetings or calls?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "No. We work asynchronously by default, so your whole project can run over email and messages on a schedule that suits you. If you'd prefer a quick call, we're happy to arrange one.",
          },
        },
        {
          "@type": "Question",
          name: "Is hosting included in your packages?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Yes, all of our monthly packages include hosting. If you choose a one-off purchase instead, we can host for you for an additional fee.",
          },
        },
        {
          "@type": "Question",
          name: "Do you offer SEO?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Yes. All of our web packages include SEO. While we cannot guarantee a top Google ranking, we follow best practices to get your website ranking as well as possible.",
          },
        },
      ],
    },
  ],
};
---

<Layout
  title="Web Design & Development Agency"
  description="KittyCode Creative, a bespoke web design agency in Eastbourne. Specialising in personalised, accessible web design, front-end development and SEO to enhance your online presence. Contact us today!"
>
  <TopBar
    content="KittyCode Creative - Bespoke Web Design & Development Agency in Eastbourne, East Sussex"
    link="https://kittycodecreative.com"
    hidden={true}
  />
  <Hero
    role="Welcome to KittyCode Creative"
    name="Web Design & Development"
    primaryCTA={{
      text: "Our Services",
      href: "#services",
    }}
    secondaryCTA={{
      text: "Contact Us",
      href: "#contact",
    }}
    bio="KittyCode Creative is a web design agency based in Eastbourne, East Sussex. We specialise in creating beautiful, professional, responsive and accessible websites, as well as front-end web development and design solutions. 
    
    Check out our portfolio below, or contact us for more information."
  />

  <TrustStrip />

  <StatsSection />
  <AboutSection />
  <FeaturesSection />
  <ProcessSection />
  <PricingSection />
  <PortfolioSection />
  <TestimonialsSection />
  <HighlightsSection />
  <FaqSection />

  <CallToAction />

  <ContactSection />

  <JsonLd data={structuredData} />
</Layout>
