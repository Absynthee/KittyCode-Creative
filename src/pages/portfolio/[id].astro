---
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/sections/PageHero.astro";
import ProjectCaseStudy from "@/components/sections/ProjectCaseStudy.astro";
import CallToAction from "@/components/sections/CallToAction.astro";
import JsonLd from "@/components/JsonLd.astro";
import { SITE_URL as siteUrl, breadcrumbs } from "@/lib/schema";

export const getStaticPaths = (async () => {
  const projects = (
    await getCollection("projects", ({ data }) => !data.draft)
  ).sort((a, b) => a.data.order - b.data.order);

  return projects.map((entry, index) => ({
    params: { id: entry.id },
    props: {
      entry,
      prev: projects[index - 1] ?? null,
      next: projects[index + 1] ?? null,
    },
  }));
}) satisfies GetStaticPaths;

const { entry, prev, next } = Astro.props;
const { data } = entry;

const pageUrl = `${siteUrl}/portfolio/${entry.id}`;
// Resolve the cover against the deploy origin (Astro.site is env-driven) so the
// og:image works on preview/branch deploys, not just the production domain.
const imageUrl = new URL(data.cover.src, Astro.site ?? siteUrl).href;

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CreativeWork",
      "@id": `${pageUrl}#project`,
      name: data.title,
      description: data.summary,
      url: data.liveUrl || pageUrl,
      image: imageUrl,
      keywords: data.tags.join(", "),
      ...(data.year ? { dateCreated: `${data.year}` } : {}),
      creator: { "@id": `${siteUrl}/#organization` },
      about: data.client,
      isPartOf: { "@id": `${siteUrl}/portfolio#webpage` },
      ...(data.testimonial
        ? {
            review: {
              "@type": "Review",
              reviewBody: data.testimonial.quote,
              author: {
                "@type": "Person",
                name: data.testimonial.author,
              },
              itemReviewed: { "@id": `${siteUrl}/#organization` },
            },
          }
        : {}),
    },
    breadcrumbs([
      { name: "Portfolio", path: "/portfolio" },
      { name: data.title, path: `/portfolio/${entry.id}` },
    ]),
  ],
};
---

<Layout title={`${data.title} Case Study`} description={data.summary} image={imageUrl}>
  <PageHero eyebrow="case study" title={data.title} lead={data.summary} />

  <ProjectCaseStudy entry={entry} prev={prev} next={next} />

  <CallToAction
    heading="Like what you see?"
    text="If you'd like a website like this, we'd love to hear about your project. Get a free, no-obligation quote today."
    primaryCTA={{ text: "Get a Free Quote", href: "/contact" }}
    secondaryCTA={{ text: "See More Work", href: "/portfolio" }}
  />

  <JsonLd data={structuredData} />
</Layout>
